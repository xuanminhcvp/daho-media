{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "updater:default",
    "shell:allow-open",
    "clipboard-manager:allow-write-text",
    {
      "identifier": "http:default",
      "allow": [
        {
          "url": "http://**"
        },
        {
          "url": "https://**"
        },
        {
          "url": "http://127.0.0.1:56003/*"
        },
        {
          "url": "http://localhost:56003/*"
        },
        {
          "url": "http://127.0.0.1:8045/*"
        },
        {
          "url": "http://localhost:8045/*"
        },
        {
          "url": "ws://**"
        },
        {
          "url": "wss://*/*"
        }
      ],
      "deny": [
        {
          "url": "https://private.tauri.app"
        }
      ]
    },
    "fs:default",
    {
      "identifier": "fs:scope",
      "allow": [
        {
          "path": "$DOCUMENT/**"
        },
        {
          "path": "$DOWNLOAD/**"
        },
        {
          "path": "$DESKTOP/**"
        },
        {
          "path": "$HOME/**"
        },
        {
          "path": "$APPCACHE/**"
        }
      ]
    },
    "fs:allow-resource-read-recursive",
    {
      "identifier": "fs:allow-write-text-file",
      "allow": [
        {
          "path": "$DOCUMENT/**"
        }
      ]
    },
    {
      "identifier": "fs:allow-exists",
      "allow": [
        {
          "path": "$DOCUMENT/**"
        }
      ]
    },
    "dialog:default",
    {
      "identifier": "dialog:allow-save",
      "allow": [
        {
          "path": "$DESKTOP/*"
        },
        {
          "path": "$DOCUMENT/*"
        },
        {
          "path": "$DOWNLOAD/*"
        }
      ]
    },
    "store:default",
    "core:window:default",
    {
      "identifier": "core:window:allow-close"
    },
    {
      "identifier": "core:window:allow-start-dragging"
    },
    {
      "identifier": "core:window:allow-minimize"
    },
    {
      "identifier": "core:window:allow-toggle-maximize"
    },
    "core:webview:allow-set-webview-zoom",
    "process:default",
    "shell:default",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "ffmpeg",
          "cmd": "ffmpeg",
          "args": true
        },
        {
          "name": "exec-sh",
          "cmd": "sh",
          "args": true
        }
      ]
    },
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        {
          "name": "ffmpeg",
          "cmd": "ffmpeg",
          "args": true
        },
        {
          "name": "exec-sh",
          "cmd": "sh",
          "args": true
        },
        {
          "name": "binaries/ffmpeg",
          "cmd": "binaries/ffmpeg",
          "args": true
        }
      ]
    },
    "os:default",
    {
      "identifier": "opener:allow-open-path",
      "allow": [
        {
          "path": "$APPLOG/**"
        },
        {
          "path": "$APPDATA/**"
        },
        {
          "path": "$APPCACHE/**"
        },
        {
          "path": "$APPLOCALDATA/**"
        }
      ]
    }
  ]
}